{
  "name": "@letscareer/ui",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "exports": {
    ".": "./src/index.ts",
